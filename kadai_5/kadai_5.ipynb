        "top_base = 10\n",
        "bottom_base = 20\n",
        "height = 5\n",
        "\n",
        "def trapezoid_colc(top_base,bottom_base,height):\n",
        "    sum1 = top_base + bottom_base\n",
        "    sum2 = sum1 * height\n",
        "    sum3 = sum2 / 2\n",
        "    return sum3\n",
        "\n",
        "print(trapezoid_colc(top_base,bottom_base,height))"
      ]
